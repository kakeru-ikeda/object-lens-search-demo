# Copy to frontend/.env.deploy or export these variables before running ./bin/deploy.
GITHUB_REPOSITORY=kakeru-ikeda/object-lens-search-demo
PAGES_BASE_PATH=/object-lens-search-demo/
PAGES_BRANCH=gh-pages
# Set true if you want deploy to stop when source files have uncommitted changes.
REQUIRE_CLEAN_TREE=false

# Cloud Run service URL printed by backend/bin/deploy.
VITE_API_BASE_URL=https://replace-with-cloud-run-url.a.run.app

# Generate with: npm run auth:hash -- "your long shared passphrase"
VITE_AUTH_PASSPHRASE_HASH=
VITE_AUTH_PASSPHRASE_SALT=
VITE_AUTH_PASSPHRASE_ITERATIONS=600000
