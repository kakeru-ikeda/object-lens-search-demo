# App runtime
APP_ENV=development
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_PER_MINUTE=30
MAX_IMAGE_BYTES=2097152
MAX_TOTAL_IMAGE_BYTES=10485760
MAX_REQUEST_BYTES=14680064
REQUEST_TIMEOUT_SECONDS=30
STREAM_REQUEST_TIMEOUT_SECONDS=120

# LLM provider
LLM_PROVIDER=bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v1:0
BEDROCK_LIGHT_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0

# AWS credentials for local/Cloud Run Bedrock access.
# Required when using real Bedrock. Not required when APP_ENV=development falls back to mock.
# Prefer AWS_PROFILE locally if you use aws configure, or inject these via Secret Manager in Cloud Run.
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_SESSION_TOKEN=

# Search provider
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=replace-with-tavily-api-key
TAVILY_ENDPOINT=https://api.tavily.com/search

# Google Cloud Vision no-vector evidence layer
# Enable to call OCR, Logo Detection, Web Detection, and Label Detection before LLM synthesis.
CLOUD_VISION_ENABLED=false
CLOUD_VISION_PROVIDER=cloudvision
GCP_PROJECT_ID=replace-with-gcp-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
