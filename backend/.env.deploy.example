# Copy to backend/.env.deploy or export these variables before running ./bin/deploy.
PROJECT_ID=object-lens-search
REGION=asia-northeast1
SERVICE_NAME=object-lens-search-api
ARTIFACT_REPOSITORY=cloud-run-source-deploy
IMAGE_NAME=object-lens-search-api
# Optional. If set, this service account runs Cloud Run and must access Secret Manager.
SERVICE_ACCOUNT=
# Grant roles/secretmanager.secretAccessor to the runtime service account before deploy.
GRANT_SECRET_ACCESS=true

# Must match the GitHub Pages origin. CORS checks only scheme + host, not path.
ALLOWED_ORIGINS=https://kakeru-ikeda.github.io

# Production runtime config.
APP_ENV=production
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
TAVILY_ENDPOINT=https://api.tavily.com/search
CLOUD_VISION_ENABLED=true
GCP_PROJECT_ID=object-lens-search
GCP_REGION=asia-northeast1

# Secret Manager secret names. Create these before deploy.
TAVILY_SECRET_NAME=tavily-api-key
AWS_ACCESS_KEY_ID_SECRET_NAME=aws-access-key-id
AWS_SECRET_ACCESS_KEY_SECRET_NAME=aws-secret-access-key
# Set only when you use temporary AWS credentials.
AWS_SESSION_TOKEN_SECRET_NAME=

# Optional Cloud Run sizing.
MEMORY=1Gi
CPU=1
TIMEOUT=300
RATE_LIMIT_PER_MINUTE=30
MAX_IMAGE_BYTES=2097152
MAX_TOTAL_IMAGE_BYTES=10485760
MAX_REQUEST_BYTES=14680064
REQUEST_TIMEOUT_SECONDS=30
STREAM_REQUEST_TIMEOUT_SECONDS=120
